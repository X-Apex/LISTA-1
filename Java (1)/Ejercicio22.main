public class TablaValores { 
    public static void main(String[] args) { 
        System.out.println("   N       N^2        N^0.5"); 
        System.out.println("--------------------------------"); 
        for (double N = 1.0; N <= 1.1; N += 0.001) { 
            double cuadrado = Math.pow(N, 2); 
            double raiz = Math.sqrt(N); 
            System.out.printf("%6.3f   %8.5f   %8.5f%n", N, cuadrado, raiz); 
        } 
    } 
} 